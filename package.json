{
  "name": "wolf-and-sheep",
  "version": "1.0.0",
  "private": true,
  "description": "Web version of the classic Wolf & Sheep (Fox & Hounds) board game with local and online multiplayer.",
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c cyan,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm run dev --workspace server",
    "dev:client": "npm run dev --workspace client",
    "build": "npm run build --workspace client",
    "typecheck": "npm run typecheck --workspace server && npm run typecheck --workspace client",
    "test": "npm run test --workspace shared",
    "start": "npm run start --workspace server"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "engines": {
    "node": ">=22.12"
  }
}
